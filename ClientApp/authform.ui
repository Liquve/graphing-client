    QLabel#label_title { font-size: 32px; font-weight: bold; color: #2f3640; margin-bottom: 10px; background-color: transparent; }

    QPushButton { background-color: #4a90e2; color: white; border: none; border-radius: 8px; padding: 12px; font-weight: bold; font-size: 14px; }
    QPushButton:hover { background-color: #357abd; }

    QPushButton#btn_register, QPushButton#btn_forget_password { background-color: transparent; color: #4a90e2; border: 1px solid #4a90e2; }
    QPushButton#btn_register:hover, QPushButton#btn_forget_password:hover { background-color: #f0f7ff; }

    QPushButton#btn_exit { background-color: transparent; color: #e74c3c; border: 1px solid #e74c3c; margin-top: 20px; }
    QPushButton#btn_exit:hover { background-color: #fab1a0; }
    QPushButton#btn_backToAbout {
