    QLabel#label_title { font-size: 26px; font-weight: bold; color: #2f3640; margin-bottom: 10px; background-color: transparent; }
    QPushButton { background-color: #4a90e2; color: white; border: none; border-radius: 8px; padding: 12px; font-weight: bold; font-size: 14px; }
    QPushButton:hover { background-color: #357abd; }
    QPushButton#btn_back { background-color: transparent; color: #4a90e2; border: 1px solid #4a90e2; }
    QPushButton#btn_exit { background-color: transparent; color: #e74c3c; border: 1px solid #e74c3c; margin-top: 10px; }
    QPushButton#btn_exit:hover { background-color: #fab1a0; }
