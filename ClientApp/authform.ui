  <property name="styleSheet">
   <string notr="true">/* 1. Идеально белый фон всего окна */
QWidget {
    background-color: white; 
    font-family: -apple-system, &quot;Helvetica Neue&quot;, Helvetica, Arial, sans-serif;
    color: black; 
}

/* 2. Заголовок &quot;Авторизация&quot; (ТЕПЕРЬ ПО ЦЕНТРУ) */
QLabel#label_title {
    font-size: 32px;
    color: black;
    margin-bottom: 15px;
    qproperty-alignment: AlignCenter; /* Выравнивание по центру */
}

/* 3. Обычные надписи (Логин, Пароль) (ТЕПЕРЬ ПО ЦЕНТРУ) */
QLabel {
    font-size: 14px;
    color: black;
}

/* 4. Поля ввода */
QLineEdit {
    background-color: #f8f9fa;
    border: 1px solid #ced4da;
    border-radius: 6px; 
    padding: 10px;      
    font-size: 14px;
    color: black;
}
QLineEdit:focus {
    border: 2px solid #8faadc; /* Рамка теперь тоже пастельного цвета */
    background-color: white;
}

/* 5. ВСЕ КНОПКИ - Мягкий пастельный синий */
QPushButton {
    background-color: #8faadc; /* Тот самый пастельный цвет */
    color: white;
    border: none;
    border-radius: 6px;
    padding: 12px;
    font-size: 14px;
    font-weight: bold;
}
/* Эффект при наведении (чуть темнее) */
QPushButton:hover {
    background-color: #7b9cd6; 
}
/* Эффект при нажатии */
QPushButton:pressed {
    background-color: #688acf; 
}</string>
