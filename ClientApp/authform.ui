   <string notr="true">
    QWidget { background-color: #f5f6fa; font-family: 'Segoe UI', sans-serif; color: #2d3436; }

    QFrame#loginContainer { background-color: white; border-radius: 15px; border: 1px solid #dcdde1; }

    QLabel { background-color: transparent; }

    QLineEdit { background-color: #ffffff; border: 2px solid #edeff2; border-radius: 8px; padding: 12px; font-size: 14px; min-width: 300px; }
