  <property name="styleSheet">
   <string notr="true">
    QWidget { background-color: #f5f6fa; font-family: 'Segoe UI', sans-serif; color: #2d3436; }
    QFrame#paper { background-color: white; border-radius: 10px; border: 1px solid #dcdde1; }
